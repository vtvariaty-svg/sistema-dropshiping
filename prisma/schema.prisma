generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id         String   @id @default(uuid()) @db.Uuid
  name       String
  plan       String   @default("free")
  created_at DateTime @default(now())

  users             User[]
  audit_logs        AuditLog[]
  shopify_stores    ShopifyStore[]
  shopify_webhooks  ShopifyWebhook[]
  dead_letter_jobs  DeadLetterJob[]
  orders            Order[]
  order_items       OrderItem[]
  order_addresses   OrderAddress[]
  order_events      OrderEvent[]
  suppliers         Supplier[]
  supplier_products SupplierProduct[]
  sku_mappings      SkuMapping[]

  @@map("tenants")
}

model User {
  id            String   @id @default(uuid()) @db.Uuid
  tenant_id     String   @db.Uuid
  email         String
  password_hash String
  role          String   @default("operator")
  created_at    DateTime @default(now())

  tenant         Tenant         @relation(fields: [tenant_id], references: [id])
  refresh_tokens RefreshToken[]
  audit_logs     AuditLog[]     @relation("actor")

  @@unique([tenant_id, email])
  @@map("users")
}

model RefreshToken {
  id         String    @id @default(uuid()) @db.Uuid
  user_id    String    @db.Uuid
  token_hash String
  revoked_at DateTime?
  expires_at DateTime
  created_at DateTime  @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@index([token_hash])
  @@map("refresh_tokens")
}

model AuditLog {
  id            String   @id @default(uuid()) @db.Uuid
  tenant_id     String   @db.Uuid
  actor_user_id String   @db.Uuid
  entity        String
  entity_id     String?
  action        String
  payload_json  Json?
  created_at    DateTime @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [id])
  actor  User   @relation("actor", fields: [actor_user_id], references: [id])

  @@index([tenant_id])
  @@map("audit_log")
}

// ─── MODULE 1: Shopify Integration ───────────────────────────────

model ShopifyStore {
  id               String   @id @default(uuid()) @db.Uuid
  tenant_id        String   @db.Uuid
  shop_domain      String
  access_token_enc String
  scopes           String
  status           String   @default("active")
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  tenant   Tenant           @relation(fields: [tenant_id], references: [id])
  webhooks ShopifyWebhook[]
  orders   Order[]
  sku_mappings SkuMapping[]

  @@unique([tenant_id, shop_domain])
  @@index([tenant_id])
  @@map("shopify_stores")
}

model ShopifyWebhook {
  id           String    @id @default(uuid()) @db.Uuid
  tenant_id    String    @db.Uuid
  store_id     String    @db.Uuid
  topic        String
  webhook_id   String
  payload_raw  Json
  received_at  DateTime  @default(now())
  processed_at DateTime?
  status       String    @default("pending")
  error        String?

  tenant Tenant       @relation(fields: [tenant_id], references: [id])
  store  ShopifyStore @relation(fields: [store_id], references: [id])

  @@index([tenant_id])
  @@index([store_id])
  @@index([status])
  @@map("shopify_webhooks")
}

model DeadLetterJob {
  id           String   @id @default(uuid()) @db.Uuid
  tenant_id    String   @db.Uuid
  job_type     String
  payload_json Json
  error        String?
  attempts     Int      @default(0)
  created_at   DateTime @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id])
  @@map("dead_letter_jobs")
}

// ─── MODULE 2: Order Pipeline ────────────────────────────────────

model Order {
  id                    String    @id @default(uuid()) @db.Uuid
  tenant_id             String    @db.Uuid
  channel               String    @default("SHOPIFY")
  store_id              String?   @db.Uuid
  external_order_id     String
  external_order_number String
  financial_status      String
  fulfillment_status    String?
  operational_status    String?   @default("NEW")
  currency              String
  subtotal              Decimal   @db.Decimal(12, 2)
  shipping              Decimal   @db.Decimal(12, 2)
  discounts             Decimal   @db.Decimal(12, 2)
  total                 Decimal   @db.Decimal(12, 2)
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  tenant    Tenant        @relation(fields: [tenant_id], references: [id])
  store     ShopifyStore? @relation(fields: [store_id], references: [id])
  items     OrderItem[]
  addresses OrderAddress[]
  events    OrderEvent[]

  @@unique([tenant_id, channel, store_id, external_order_id])
  @@index([tenant_id])
  @@index([operational_status])
  @@map("orders")
}

model OrderItem {
  id                    String  @id @default(uuid()) @db.Uuid
  tenant_id             String  @db.Uuid
  order_id              String  @db.Uuid
  external_line_item_id String
  sku                   String?
  variant_id            String?
  title                 String
  qty                   Int
  price                 Decimal @db.Decimal(12, 2)
  discount              Decimal @db.Decimal(12, 2) @default(0)

  tenant Tenant @relation(fields: [tenant_id], references: [id])
  order  Order  @relation(fields: [order_id], references: [id])

  @@index([order_id])
  @@map("order_items")
}

model OrderAddress {
  id        String  @id @default(uuid()) @db.Uuid
  tenant_id String  @db.Uuid
  order_id  String  @db.Uuid
  type      String
  name      String?
  phone     String?
  address1  String?
  address2  String?
  city      String?
  province  String?
  zip       String?
  country   String?

  tenant Tenant @relation(fields: [tenant_id], references: [id])
  order  Order  @relation(fields: [order_id], references: [id])

  @@index([order_id])
  @@map("order_addresses")
}

model OrderEvent {
  id           String   @id @default(uuid()) @db.Uuid
  tenant_id    String   @db.Uuid
  order_id     String?  @db.Uuid
  channel      String
  type         String
  payload_json Json?
  created_at   DateTime @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [id])
  order  Order? @relation(fields: [order_id], references: [id])

  @@index([tenant_id])
  @@index([order_id])
  @@map("order_events")
}

// ─── MODULE 3: Suppliers & SKU Mapping ───────────────────────────

model Supplier {
  id            String   @id @default(uuid()) @db.Uuid
  tenant_id     String   @db.Uuid
  name          String
  contact_email String?
  contact_name  String?
  phone         String?
  notes         String?
  status        String   @default("active")
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  tenant   Tenant            @relation(fields: [tenant_id], references: [id])
  products SupplierProduct[]
  mappings SkuMapping[]

  @@index([tenant_id])
  @@map("suppliers")
}

model SupplierProduct {
  id             String   @id @default(uuid()) @db.Uuid
  tenant_id      String   @db.Uuid
  supplier_id    String   @db.Uuid
  supplier_sku   String
  name           String
  cost           Decimal  @db.Decimal(12, 2)
  currency       String   @default("USD")
  stock_hint     Int?
  lead_time_days Int?
  source_url     String?
  active         Boolean  @default(true)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  tenant   Tenant      @relation(fields: [tenant_id], references: [id])
  supplier Supplier    @relation(fields: [supplier_id], references: [id])
  mappings SkuMapping[]

  @@unique([tenant_id, supplier_id, supplier_sku])
  @@index([tenant_id])
  @@index([supplier_id])
  @@map("supplier_products")
}

model SkuMapping {
  id                  String   @id @default(uuid()) @db.Uuid
  tenant_id           String   @db.Uuid
  channel             String   @default("SHOPIFY")
  store_id            String?  @db.Uuid
  shopify_sku         String?
  shopify_variant_id  String?
  supplier_id         String   @db.Uuid
  supplier_product_id String   @db.Uuid
  active              Boolean  @default(true)
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  tenant          Tenant           @relation(fields: [tenant_id], references: [id])
  store           ShopifyStore?    @relation(fields: [store_id], references: [id])
  supplier        Supplier         @relation(fields: [supplier_id], references: [id])
  supplier_product SupplierProduct @relation(fields: [supplier_product_id], references: [id])

  @@index([tenant_id])
  @@index([supplier_id])
  @@map("sku_mappings")
}
