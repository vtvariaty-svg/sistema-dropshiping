# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:pass@host:5432/dropship_saas?sslmode=require

# JWT Secrets (min 32 characters each)
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars

# Cookie
COOKIE_SECRET=change-me-cookie-secret-min-32-chars

# Frontend URL (for CORS) — set to your Render frontend URL
WEB_BASE_URL=https://dropship-web.onrender.com

# Server
PORT=3001
NODE_ENV=production
